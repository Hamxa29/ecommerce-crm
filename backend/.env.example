DATABASE_URL=postgresql://postgres:password@localhost:5432/ecommerce_crm

JWT_SECRET=change-this-to-a-random-32-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EVOLUTION_API_URL=https://your-vps-ip:port
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name

PORT=3001
NODE_ENV=development

CORS_ORIGIN=http://localhost:5173

# ── Email / SMTP (for order notification emails) ─────────────────────────────
# Works with Gmail, SendGrid, Brevo, Mailgun, any SMTP provider
# For Gmail: use App Password (not your normal password)
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="My Store" <your-gmail@gmail.com>

# Set notification email(s) in Settings page UI — no env var needed

# ── Delivery Monitor Bot ───────────────────────────────────────────────────────
# The Evolution API instance name for the second (delivery bot) WhatsApp number
# Create this instance in your Evolution API dashboard and set the same name here
DELIVERY_MONITOR_INSTANCE=delivery-monitor
